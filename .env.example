# AI Gateway Server 環境配置範例
PORT=3005
DATA_DIR=./data
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=meta/llama-3.1-8b-instruct
SUMMARY_MODEL=meta/llama-3.3-70b-instruct
SUMMARY_TIME=23:55
MAX_QUEUE_SIZE=100
SESSION_TIMEOUT=300000
# v2: 每 key 最大併發數（同一 API Key 可同時服務多少 session）
MAX_CONCURRENT_PER_KEY=5
# v2: 僵死 session 自動回收超時（ms），防止 acquire 後未 release 導致槽位洩漏
KEY_STALE_TIMEOUT=120000
